C_MAIN, C_HL, C_TITLE, C_ERR, C_SUCCESS = 1, 2, 3, 4, 5

def init_colors():
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(C_MAIN, curses.COLOR_WHITE, -1)
    curses.init_pair(C_HL, curses.COLOR_BLACK, curses.COLOR_CYAN)
    curses.init_pair(C_TITLE, curses.COLOR_CYAN, -1)
    curses.init_pair(C_ERR, curses.COLOR_RED, -1)
    curses.init_pair(C_SUCCESS, curses.COLOR_GREEN, -1)

def str_width(s): return sum(2 if unicodedata.east_asian_width(c) in 'WF' else 1 for c in str(s))
def pad_str(s, width): return s + " " * max(0, width - str_width(s))

def truncate_str(s, max_width):
    w = 0; res =[]
    for c in str(s):
        cw = str_width(c)
        if w + cw > max_width: break
        res.append(c); w += cw
    return "".join(res)

def _safe_addstr(win, y, x, text, attr=0):
    try: win.addstr(y, x, text, attr)
    except curses.error: pass

def draw_box(stdscr, y, x, h, w, title=""):
    stdscr.attron(curses.color_pair(C_TITLE))
    _safe_addstr(stdscr, y, x, "┌" + "─"*(w-2) + "┐")
    for r in range(1, h-1): _safe_addstr(stdscr, y+r, x, "│" + " "*(w-2) + "│")
    _safe_addstr(stdscr, y+h-1, x, "└" + "─"*(w-2) + "┘")
    if title: _safe_addstr(stdscr, y, x+2, f" {title} ", curses.A_BOLD)
    stdscr.attroff(curses.color_pair(C_TITLE))

def msgbox(stdscr, title, text):
    stdscr.timeout(-1)
    lines = text.split('\n')
    sh, sw = stdscr.getmaxyx()
    w = min(sw - 4, max(40, max((str_width(l) for l in lines), default=0) + 4))
    h = min(sh - 4, len(lines) + 4)
    y, x = (sh - h) // 2, (sw - w) // 2
    
    stdscr.erase()
    draw_box(stdscr, y, x, h, w, title)
    for i, l in enumerate(lines):
        if i >= h - 4: break
        _safe_addstr(stdscr, y + 2 + i, x + 2, l, curses.color_pair(C_MAIN))
    _safe_addstr(stdscr, y + h - 1, x + w - str_width(t('tui_btn_ok')) - 4, t('tui_btn_ok'), curses.color_pair(C_TITLE))
    stdscr.refresh()
    while True:
        k = stdscr.getch()
        if k in (10, 13, 27, ord('q'), ord('Q')): break

def textarea_dialog(stdscr, title, text):
    stdscr.timeout(-1)
    chars = list(text)
    cursor = len(chars)
    
    while True:
        sh, sw = stdscr.getmaxyx()
        h, w = int(sh*0.8), int(sw*0.9)
        y, x = (sh-h)//2, (sw-w)//2
        
        stdscr.erase()
        draw_box(stdscr, y, x, h, w, title)
        _safe_addstr(stdscr, y+h-1, x+2, t('tui_hint_textarea'), curses.color_pair(C_TITLE))
        
        lines, curr_line, curr_w, cursor_pos = [],[], 0, (0, 0)
        for i, ch in enumerate(chars + ['']):
            if i == cursor: cursor_pos = (len(lines), str_width(''.join(curr_line)))
            if ch == '\n':
                lines.append(''.join(curr_line)); curr_line, curr_w =[], 0
            elif ch != '':
                cw = str_width(ch)
                if curr_w + cw > w - 4:
                    lines.append(''.join(curr_line)); curr_line, curr_w =[ch], cw
                else: curr_line.append(ch); curr_w += cw
        if curr_line or (chars and chars[-1] == '\n'): lines.append(''.join(curr_line))
        if not lines: lines =[""]
        
        max_lines = h - 2
        start_row = max(0, cursor_pos[0] - max_lines + 1)
        for r in range(max_lines):
            lr = start_row + r
            if lr < len(lines): _safe_addstr(stdscr, y+1+r, x+2, lines[lr], curses.color_pair(C_MAIN))
        
        cy, cx = y + 1 + cursor_pos[0] - start_row, x + 2 + cursor_pos[1]
        if y + 1 <= cy < y + h - 1:
            c_char = chars[cursor] if cursor < len(chars) and chars[cursor] != '\n' else " "
            _safe_addstr(stdscr, cy, cx, c_char, curses.A_REVERSE)
        
        stdscr.refresh()
        try: k = stdscr.get_wch()
        except: continue
        code, char = (k, "") if isinstance(k, int) else (ord(k), k)
        
        if code in (27, 9): return "".join(chars)
        elif code == curses.KEY_LEFT: cursor = max(0, cursor - 1)
        elif code == curses.KEY_RIGHT: cursor = min(len(chars), cursor + 1)
        elif code == curses.KEY_UP: cursor = max(0, cursor - 30)
        elif code == curses.KEY_DOWN: cursor = min(len(chars), cursor + 30)
        elif code in (curses.KEY_BACKSPACE, 127, 8):
            if cursor > 0: chars.pop(cursor - 1); cursor -= 1
        elif code in (10, 13): chars.insert(cursor, '\n'); cursor += 1
        elif char.isprintable(): chars.insert(cursor, char); cursor += 1

def menu_dialog(stdscr, title, options, default_idx=0, hint=None, allow_delete=False, allow_undo=False, allow_search=False):
    if hint is None: hint = t('tui_hint_menu')
    if allow_search: hint += t('tui_hint_search')
    stdscr.timeout(-1)
    sh, sw = stdscr.getmaxyx()
    
    h = min(sh - 4, len(options) + 4)
    h = max(h, 6)
    w = min(sw - 4, max(40, max((str_width(o[0]) for o in options), default=0) + 10))
    y, x = (sh - h) // 2, (sw - w) // 2
    
    sel = default_idx
    filter_str = ""
    filter_mode = False
    
    while True:
        stdscr.erase()
        draw_box(stdscr, y, x, h, w, title)
        
        if filter_str:
            filtered_opts = [o for o in options if filter_str.lower() in o[0].lower()]
        else:
            filtered_opts = options
            
        sel = max(0, min(sel, max(0, len(filtered_opts) - 1)))
        
        current_hint = t('tui_sm_srch', filter_str) if filter_mode else f" {hint} "
        _safe_addstr(stdscr, y + h - 1, x + 2, current_hint, curses.color_pair(C_TITLE) | (curses.A_BOLD if filter_mode else 0))
        
        list_h = h - 2
        start_idx = max(0, min(sel - list_h // 2, len(filtered_opts) - list_h))
        
        if not filtered_opts:
            _safe_addstr(stdscr, y + 1, x + 2, pad_str(t('tui_menu_no_match'), w - 4), curses.color_pair(C_MAIN))
        else:
            for i in range(list_h):
                idx = start_idx + i
                if idx >= len(filtered_opts): break
                text = filtered_opts[idx][0]
                
                disp_w, vis_str = 0, ""
                for ch in text:
                    cw = str_width(ch)
                    if disp_w + cw > w - 4: break
                    vis_str += ch; disp_w += cw
                    
                attr = curses.color_pair(C_HL) if idx == sel else curses.color_pair(C_MAIN)
                _safe_addstr(stdscr, y + 1 + i, x + 2, pad_str(vis_str, w - 4), attr)
            
        stdscr.refresh()
        try: k = stdscr.get_wch()
        except curses.error: continue
        code, char = (k, "") if isinstance(k, int) else (ord(k), k)
        
        if filter_mode:
            if code in (27, curses.KEY_F3): 
                filter_mode = False
                filter_str = ""
            elif code in (10, 13): 
                filter_mode = False
                if filtered_opts: 
                    return ('SELECT', filtered_opts[sel][1]) if allow_delete else filtered_opts[sel][1]
            elif code in (curses.KEY_BACKSPACE, 127, 8):
                filter_str = filter_str[:-1]
            elif char.isprintable():
                filter_str += char
            continue
            
        if code in (27, ord('q'), ord('Q')): return ('QUIT', None) if allow_delete else None
        elif code in (curses.KEY_UP, ord('k')): sel = max(0, sel - 1)
        elif code in (curses.KEY_DOWN, ord('j')): sel = min(len(filtered_opts) - 1, sel + 1)
        elif code == ord('/') and allow_search: 
            filter_mode = True
            filter_str = "" 
        elif code == ord('d') and allow_delete and filtered_opts and filtered_opts[sel][1] != "NEW": return ('DELETE', filtered_opts[sel][1])
        elif code == ord('u') and allow_undo: return ('UNDO', None)
        elif code in (10, 13):
            if not filtered_opts: continue
            return ('SELECT', filtered_opts[sel][1]) if allow_delete else filtered_opts[sel][1]

def form_dialog(stdscr, title, fields, show_delete=False):
    stdscr.timeout(-1)
    sh, sw = stdscr.getmaxyx()
    h = min(sh - 2, len(fields) * 2 + 6)
    w = min(sw - 2, 80)
    y, x = (sh - h) // 2, (sw - w) // 2
    
    sel = 0
    mode = "NAV" 
    btn_save_idx = len(fields)
    btn_cancel_idx = len(fields) + 1
    btn_del_idx = len(fields) + 2 if show_delete else -1
    max_sel = len(fields) + (2 if show_delete else 1)
    
    cursors = [len(str(f["value"])) if f.get("type") != "select" else 0 for f in fields]
    scrolls = [0 for _ in fields]

    while True:
        stdscr.erase()
        draw_box(stdscr, y, x, h, w, title)
        
        hint = t('tui_hint_form_nav') if mode == "NAV" else t('tui_hint_form_edit')
        _safe_addstr(stdscr, y + h - 1, x + 2, hint, curses.color_pair(C_TITLE))
        
        for i, f in enumerate(fields):
            fy = y + 2 + i * 2
            _safe_addstr(stdscr, fy, x + 2, f["label"], curses.color_pair(C_TITLE))
            
            val = str(f["value"])
            field_w = w - 4 - str_width(f["label"]) - 2
            fx = x + 4 + str_width(f["label"])
            attr = curses.color_pair(C_HL) if (sel == i and mode == "NAV") else curses.A_UNDERLINE
            
            if f.get("type") == "textarea":
                vis = t('tui_placeholder_ta') if sel == i else truncate_str(val.replace('\n', ' '), field_w)
                _safe_addstr(stdscr, fy, fx, pad_str(vis, field_w), attr)
                continue
                
            # 渲染 Select 控件 (带有下三角提示)
            if f.get("type") == "select":
                vis = f" {val} ▾" if sel == i else f" {val}"
                _safe_addstr(stdscr, fy, fx, pad_str(vis, field_w), attr)
                continue

            disp_val = val + " "
            if cursors[i] < scrolls[i]: scrolls[i] = cursors[i]
            elif cursors[i] >= scrolls[i] + field_w: scrolls[i] = cursors[i] - field_w + 1
            
            vis = disp_val[scrolls[i]:scrolls[i]+field_w]
            cursor_rel = cursors[i] - scrolls[i]
            
            left_str = vis[:cursor_rel]
            cursor_char = vis[cursor_rel] if cursor_rel < len(vis) else " "
            right_str = vis[cursor_rel+1:]
            
            _safe_addstr(stdscr, fy, fx, left_str, attr)
            if sel == i and mode == "EDIT":
                _safe_addstr(stdscr, fy, fx + str_width(left_str), cursor_char, curses.A_REVERSE)
            else:
                _safe_addstr(stdscr, fy, fx + str_width(left_str), cursor_char, attr)
            _safe_addstr(stdscr, fy, fx + str_width(left_str) + str_width(cursor_char), right_str, attr)
            
            filled = str_width(left_str) + str_width(cursor_char) + str_width(right_str)
            if filled < field_w:
                _safe_addstr(stdscr, fy, fx + filled, " " * (field_w - filled), attr)

        by = y + h - 3
        bx = x + 8
        _safe_addstr(stdscr, by, bx, t('tui_btn_save'), curses.color_pair(C_HL) if sel == btn_save_idx else curses.color_pair(C_MAIN))
        bx += str_width(t('tui_btn_save')) + 4
        _safe_addstr(stdscr, by, bx, t('tui_btn_cancel'), curses.color_pair(C_HL) if sel == btn_cancel_idx else curses.color_pair(C_MAIN))
        if show_delete:
            bx += str_width(t('tui_btn_cancel')) + 4
            _safe_addstr(stdscr, by, bx, t('tui_btn_del'), curses.color_pair(C_ERR) | curses.A_REVERSE if sel == btn_del_idx else curses.color_pair(C_ERR))

        stdscr.refresh()
        try: k = stdscr.get_wch()
        except curses.error: continue
        code, char = (k, "") if isinstance(k, int) else (ord(k), k)

        if mode == "NAV":
            if code in (27, ord('q'), ord('Q')): 
                return None
            elif code in (10, 13, ord('i'), ord('I')):
                if sel == btn_cancel_idx: return None
                elif sel == btn_save_idx: return [str(f["value"]) for f in fields]
                elif sel == btn_del_idx: return "DELETE"
                elif sel < len(fields):
                    # 拦截 Select 控件，直接打开菜单
                    if fields[sel].get("type") == "select":
                        f_sel = fields[sel]
                        opts = [(o, o) for o in f_sel["options"]]
                        try: def_idx = f_sel["options"].index(f_sel["value"])
                        except: def_idx = 0
                        choice = menu_dialog(stdscr, f_sel["label"], opts, default_idx=def_idx)
                        if choice and choice != 'QUIT':
                            f_sel["value"] = choice
                    elif fields[sel].get("type") == "textarea":
                        fields[sel]["value"] = textarea_dialog(stdscr, fields[sel]["label"], fields[sel]["value"])
                        cursors[sel] = len(fields[sel]["value"])
                    else:
                        mode = "EDIT"
            elif code == 9: sel = (sel + 1) % (max_sel + 1)
            elif code in (curses.KEY_DOWN, ord('j')): sel = min(max_sel, sel + 1)
            elif code in (curses.KEY_UP, ord('k')): sel = max(0, sel - 1)
            elif sel >= len(fields):
                if code in (curses.KEY_LEFT, ord('h')): sel = max(len(fields), sel - 1)
                elif code in (curses.KEY_RIGHT, ord('l')): sel = min(max_sel, sel + 1)
        else:
            current_val = str(fields[sel]["value"])
            c = cursors[sel]
            
            if code in (27, 10, 13): mode = "NAV" 
            elif code == curses.KEY_LEFT: cursors[sel] = max(0, c - 1)
            elif code == curses.KEY_RIGHT: cursors[sel] = min(len(current_val), c + 1)
            elif code in (curses.KEY_BACKSPACE, 127, 8):
                if c > 0:
                    fields[sel]["value"] = current_val[:c-1] + current_val[c:]
                    cursors[sel] -= 1
            elif char.isprintable():
                fields[sel]["value"] = current_val[:c] + char + current_val[c:]
                cursors[sel] += 1

