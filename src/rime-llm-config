def load_state():
    default_state = get_default_state()
    if not os.path.exists(STATE_FILE): return default_state
    try:
        with open(STATE_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            for k in default_state:
                if k not in data: data[k] = default_state[k]
            for pk, pv in default_state["profiles"].items():
                if pk not in data["profiles"]: data["profiles"][pk] = pv
            if "max_time" not in data["settings"]: data["settings"]["max_time"] = 30.0
            return data
    except Exception: return default_state

def save_state(state):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(STATE_FILE, "w", encoding="utf-8") as f:
        json.dump(state, f, ensure_ascii=False, indent=4)

def export_to_lua(state):
    vocab_str = "\n# -------- 常用英文/网络黑话 --------\n"
    for term in state["vocab"].get("terms",[]): vocab_str += f"{term}\n"
    vocab_str += "\n# -------- 首字母简拼/拼音缩写映射 --------\n"
    for k, v in state["vocab"].get("mappings", {}).items(): vocab_str += f"{k}={v}\n"

    profiles_str = ""
    for pid, p in state["profiles"].items():
        profiles_str += f"""
        {pid} = {{
            name = "{p.get('name', pid)}",
            api_url = "{p.get('api_url', '')}",
            api_key = "{p.get('api_key', '')}",
            model = "{p.get('model', '')}",
        }},"""

    settings = state["settings"]
    lua_code = f"""-- =========================================================
-- 文件名：config.lua
-- 存放位置：~/.config/rime-llm-translator/
-- 由 rime-llm-config 自动生成，请勿手动修改此文件！
-- =========================================================

return {{
    active_profile = "{state.get('active_profile', '')}",
    profiles = {{{profiles_str}
    }},
    ai_trigger = "{settings.get('ai_trigger', 'v')}",
    prompt = "{settings.get('prompt', '')}",
    max_tokens = {settings.get('max_tokens', 4000)},
    temperature = {settings.get('temperature', 0.1)},
    connect_timeout = {settings.get('connect_timeout', 2.0)}, 
    max_time = {settings.get('max_time', 30.0)},
    thinking_mode = "{settings.get('thinking_mode', '')}",
    vocab_text = [[{vocab_str}    ]]
}}
"""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(LUA_FILE, "w", encoding="utf-8") as f: f.write(lua_code)
    return LUA_FILE

