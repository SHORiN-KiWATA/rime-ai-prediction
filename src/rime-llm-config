        self.state = state
        self._sync_from_state()
        self.active_col, self.prov_idx, self.org_idx, self.model_idx = 0, 0, 0, 0
        self.scrolls =[0, 0, 0]
        self.raw_models, self.parsed_tree, self.org_list, self.model_list = [], {}, [],[]
        self.show_org, self.loading, self.error, self.filter_str, self.filter_mode = False, False, "", "", False
        self.status_msg, self.status_flash, self.fetch_seq = "", 0, 0

    def _sync_from_state(self):
        self.providers =[]
        for pid, p in self.state["profiles"].items():
            self.providers.append({"id": pid, "name": p.get("name", pid), "api_url": p.get("api_url", ""), "api_key": p.get("api_key", ""), "model": p.get("model", "")})
        self.providers.sort(key=lambda x: x["name"].lower())
        if not self.providers: self.providers.append({"id": "empty", "name": "No Providers", "api_url": "", "api_key": "", "model": ""})

    def run(self):
        self._trigger_fetch()
        while True:
            self.stdscr.timeout(100)
            self._draw()
            try: k = self.stdscr.get_wch()
            except curses.error:
                if self.status_flash > 0: self.status_flash -= 1
                else: self.status_msg = ""
                continue
            
            self.stdscr.timeout(-1)
            if not self._handle_key(k): break

    def _trigger_fetch(self):
        if not self.providers or self.providers[0]["id"] == "empty": return
        prov = self.providers[self.prov_idx]
        self.raw_models, self.parsed_tree, self.org_list, self.model_list = [], {},[],[]
        self.org_idx, self.model_idx, self.scrolls[1], self.scrolls[2] = 0, 0, 0, 0
        self.filter_str, self.filter_mode, self.loading, self.error, self.show_org = "", False, True, "", False
        self.fetch_seq += 1
        seq = self.fetch_seq

        def worker():
            m, err = fetch_models(prov["api_url"], prov["api_key"])
            if getattr(self, 'fetch_seq', 0) != seq: return
            self.raw_models, self.error, self.loading = m, err or "", False
            self._rebuild_tree()

        threading.Thread(target=worker, daemon=True).start()

    def _rebuild_tree(self):
        if not self.raw_models:
            self.org_list, self.show_org =[], False
            self._update_model_list()
            return
        prov = self.providers[self.prov_idx]
        f = self.filter_str.lower()
        v_models =[m for m in self.raw_models if not f or f in m.lower()]
        self.parsed_tree = {"All":[]}
        for m in v_models:
            org = m.split("/", 1)[0] if "/" in m else prov["name"]
            self.parsed_tree["All"].append({"name": m.split("/", 1)[-1] if "/" in m else m, "full": m})
            if org.lower() not in ["models", prov["name"].lower()]:
                if org not in self.parsed_tree: self.parsed_tree[org] =[]
                self.parsed_tree[org].append({"name": m.split("/", 1)[-1], "full": m})
        self.org_list = ["All"] + sorted([k for k in self.parsed_tree.keys() if k != "All"])
        self.show_org = len(self.org_list) > 1
        self.org_idx = min(self.org_idx, max(0, len(self.org_list) - 1))
        self._update_model_list()

    def _update_model_list(self):
        if not self.org_list: self.model_list =[]
        else: self.model_list = sorted(self.parsed_tree[self.org_list[self.org_idx]], key=lambda x: x["name"].lower())
        self.model_idx = min(self.model_idx, max(0, len(self.model_list) - 1))
        
        if not self.show_org and self.active_col == 1: self.active_col = 2

    def _handle_key(self, k):
        code, char = (k, "") if isinstance(k, int) else (ord(k), k)

        if self.filter_mode:
            if code in (27, curses.KEY_F3):
                self.filter_mode = False
                self.filter_str = "" 
                self._rebuild_tree()
                return True
            elif code in (10, 13): 
                self.filter_mode = False
                return True 
            elif code in (curses.KEY_BACKSPACE, 127, 8): 
                self.filter_str = self.filter_str[:-1]; self._rebuild_tree()
            elif char.isprintable(): 
                self.filter_str += char; self._rebuild_tree()
            return True

        if code in (27, ord('q'), ord('Q')): return False

        if code == curses.KEY_LEFT or char.lower() == 'h':
            if self.active_col == 2: self.active_col = 1 if self.show_org else 0
            elif self.active_col == 1: self.active_col = 0
        elif code == curses.KEY_RIGHT or char.lower() == 'l':
            if self.active_col == 0: self.active_col = 1 if self.show_org and self.org_list else (2 if not self.show_org and self.model_list else 0)
            elif self.active_col == 1 and self.model_list: self.active_col = 2
        elif code == curses.KEY_DOWN or char.lower() == 'j':
            if self.active_col == 0 and self.prov_idx < len(self.providers) - 1: self.prov_idx += 1; self._trigger_fetch()
            elif self.active_col == 1 and self.org_idx < len(self.org_list) - 1: self.org_idx += 1; self._update_model_list()
            elif self.active_col == 2 and self.model_idx < len(self.model_list) - 1: self.model_idx += 1
        elif code == curses.KEY_UP or char.lower() == 'k':
            if self.active_col == 0 and self.prov_idx > 0: self.prov_idx -= 1; self._trigger_fetch()
            elif self.active_col == 1 and self.org_idx > 0: self.org_idx -= 1; self._update_model_list()
            elif self.active_col == 2 and self.model_idx > 0: self.model_idx -= 1
        elif char == '/': 
            self.filter_mode = True
            self.filter_str = "" 
            self._rebuild_tree()
        elif char.lower() == 'r': self._trigger_fetch()
        elif char.lower() == 'a':
            res = form_dialog(self.stdscr, t('tui_sm_add_prov'),[{"label": t('tui_sm_lbl_id'),"value":""}, {"label":t('tui_sm_lbl_name'),"value":""}, {"label":t('tui_sm_lbl_url'),"value":""}, {"label":t('tui_sm_lbl_key'),"value":""}])
            if res:
                pid = res[0].strip()
                if not re.match(r'^[a-zA-Z_][a-zA-Z0-9_]*$', pid):
                    self.status_msg, self.status_flash = t('tui_sm_err_id_invalid'), 30
                    return True
                if pid in self.state["profiles"]:
                    self.status_msg, self.status_flash = t('tui_sm_err_id_exist'), 30
                    return True
                
                norm_url = normalize_api_url(res[2])
                self.state["profiles"][pid] = {"name": res[1], "api_url": norm_url, "api_key": res[3], "model": ""}
                save_state(self.state)
                self._sync_from_state()
                for i, prov in enumerate(self.providers):
                    if prov["id"] == pid: self.prov_idx = i; break
                self._trigger_fetch()
        elif char.lower() == 'd' and self.active_col == 0 and self.providers[self.prov_idx]["id"] != "empty":
            pid = self.providers[self.prov_idx]["id"]
            if pid == self.state.get("active_profile"): self.state["active_profile"] = ""
            del self.state["profiles"][pid]
            save_state(self.state); self.prov_idx = max(0, self.prov_idx - 1); self._sync_from_state(); self._trigger_fetch()
        elif code in (10, 13, ord('i'), ord('I')):
            if self.active_col == 0 and self.providers[0]["id"] != "empty":
                p = self.providers[self.prov_idx]
                res = form_dialog(self.stdscr, t('tui_sm_edit_prov', p['name']),[
                    {"label":t('tui_sm_lbl_id'),"value":p["id"]}, 
                    {"label":t('tui_sm_lbl_name'),"value":p["name"]}, 
                    {"label":t('tui_sm_lbl_url'),"value":p["api_url"]}, 
                    {"label":t('tui_sm_lbl_key'),"value":p["api_key"]}
                ])
                if res:
                    new_id = res[0].strip()
                    if not re.match(r'^[a-zA-Z_][a-zA-Z0-9_]*$', new_id):
                        self.status_msg, self.status_flash = t('tui_sm_err_id_invalid'), 30
                        return True
                    if new_id != p["id"] and new_id in self.state["profiles"]:
                        self.status_msg, self.status_flash = t('tui_sm_err_id_exist'), 30
                        return True
                        
                    if new_id != p["id"]:
                        self.state["profiles"][new_id] = self.state["profiles"].pop(p["id"])
                        if self.state.get("active_profile") == p["id"]:
                            self.state["active_profile"] = new_id

                    norm_url = normalize_api_url(res[2])
                    self.state["profiles"][new_id].update({"name": res[1], "api_url": norm_url, "api_key": res[3]})
                    save_state(self.state)
                    self._sync_from_state()
                    for i, prov in enumerate(self.providers):
                        if prov["id"] == new_id: self.prov_idx = i; break
                    self._trigger_fetch()
            elif self.active_col == 2 and self.model_list:
                m = self.model_list[self.model_idx]["full"]
                pid = self.providers[self.prov_idx]["id"]
                self.state["profiles"][pid]["model"] = m
                save_state(self.state); self._sync_from_state()
                self.status_msg, self.status_flash = t('tui_sm_set_succ', m, self.providers[self.prov_idx]['name']), 30

        if self.status_flash > 0: self.status_flash -= 1
        else: self.status_msg = ""
        return True

    def _draw(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        w1 = max(22, min(32, max((str_width(p["name"]) for p in self.providers), default=20) + 4))
        w2 = max(22, min(32, max((str_width(o) for o in self.org_list), default=20) + 4)) if self.show_org else 0
        w3 = w - w1 - w2 - (2 if self.show_org else 1)

        for row in range(0, h):
            _safe_addstr(self.stdscr, row, w1, "│", curses.color_pair(C_TITLE) | curses.A_DIM)
            if self.show_org: _safe_addstr(self.stdscr, row, w1 + 1 + w2, "│", curses.color_pair(C_TITLE) | curses.A_DIM)

        if self.status_msg: msg, attr = f" {self.status_msg} ", curses.color_pair(C_SUCCESS)|curses.A_BOLD
        elif self.filter_mode: msg, attr = t('tui_sm_srch', self.filter_str), curses.color_pair(C_TITLE)|curses.A_BOLD
        else: msg, attr = t('tui_sm_nav'), curses.color_pair(C_TITLE)
        
        _safe_addstr(self.stdscr, h - 1, 0, pad_str(msg, w)[:w], attr)

        self._draw_list(0, h - 1, w1, t('tui_sm_prov'), [p["name"] for p in self.providers], self.prov_idx, 0, 0)
        if self.show_org: 
            self._draw_list(w1 + 1, h - 1, w2, t('tui_sm_org'), self.org_list, self.org_idx, 1, 1)
            m_x = w1 + 1 + w2 + 1
        else:
            m_x = w1 + 1
            
        self._draw_models(m_x, h - 1, w3, 2)
        self.stdscr.refresh()

    def _draw_list(self, x_offset, h, w, title, items, cur_idx, scroll_idx, col_idx):
        _safe_addstr(self.stdscr, 0, x_offset, "─" * w, curses.color_pair(C_TITLE) | curses.A_DIM)
        _safe_addstr(self.stdscr, 0, x_offset + max(0, (w - str_width(title)) // 2), title, curses.color_pair(C_HL if self.active_col == col_idx else C_TITLE))
        list_h = h - 2
        if cur_idx < self.scrolls[scroll_idx]: self.scrolls[scroll_idx] = cur_idx
        elif cur_idx >= self.scrolls[scroll_idx] + list_h: self.scrolls[scroll_idx] = cur_idx - list_h + 1
        for i in range(list_h):
            idx = i + self.scrolls[scroll_idx]
            if idx >= len(items): break
            is_cur = (idx == cur_idx) and (col_idx <= self.active_col)
            attr = curses.color_pair(C_HL) if (is_cur and self.active_col == col_idx) else (curses.color_pair(C_TITLE)|curses.A_REVERSE if is_cur else curses.color_pair(C_TITLE))
            
            disp_w, vis_str = 0, ""
            prefix = "► " if is_cur and self.active_col == col_idx else "  "
            for ch in prefix + items[idx]:
                cw = str_width(ch)
                if disp_w + cw > w - 1: break
                vis_str += ch; disp_w += cw
                
            _safe_addstr(self.stdscr, i + 1, x_offset, pad_str(vis_str, w - 1), attr)
        _safe_addstr(self.stdscr, h - 1, x_offset, "─" * w, curses.color_pair(C_TITLE) | curses.A_DIM)

    def _draw_models(self, x_offset, h, w, col_idx):
        title = t('tui_sm_mod_srch', self.filter_str) if self.filter_str else t('tui_sm_mod')
        _safe_addstr(self.stdscr, 0, x_offset, "─" * w, curses.color_pair(C_TITLE) | curses.A_DIM)
        _safe_addstr(self.stdscr, 0, x_offset + max(0, (w - str_width(title)) // 2), title, curses.color_pair(C_HL if self.active_col == col_idx else C_TITLE))

        if self.loading: 
            _safe_addstr(self.stdscr, 2, x_offset + 2, t('tui_sm_fetch'), curses.color_pair(C_TITLE))
        elif self.error: 
            err_str = t('tui_sm_err', str(self.error).replace('\n', ' '))
            err_msg = truncate_str(err_str, w - 4)
            _safe_addstr(self.stdscr, 2, x_offset + 2, err_msg, curses.color_pair(C_ERR))
        elif not self.model_list: 
            _safe_addstr(self.stdscr, 2, x_offset + 2, t('tui_sm_no_mod'), curses.color_pair(C_TITLE))
        else:
            list_h = h - 2
            if self.model_idx < self.scrolls[2]: self.scrolls[2] = self.model_idx
            elif self.model_idx >= self.scrolls[2] + list_h: self.scrolls[2] = self.model_idx - list_h + 1
            for i in range(list_h):
                idx = i + self.scrolls[2]
                if idx >= len(self.model_list): break
                m_name = self.model_list[idx]['name']
                if self.providers[self.prov_idx]["model"] == self.model_list[idx]["full"]: m_name += "[Current]"
                is_cur = (idx == self.model_idx) and (self.active_col >= col_idx)
                attr = curses.color_pair(C_HL) if (is_cur and self.active_col == col_idx) else (curses.color_pair(C_TITLE)|curses.A_REVERSE if is_cur else curses.color_pair(C_TITLE))
                
                disp_w, vis_str = 0, ""
                prefix = "► " if is_cur and self.active_col == col_idx else "  "
                for ch in prefix + m_name:
                    cw = str_width(ch)
                    if disp_w + cw > w - 1: break
                    vis_str += ch; disp_w += cw
                    
                _safe_addstr(self.stdscr, i + 1, x_offset, pad_str(vis_str, w - 1), attr)
        _safe_addstr(self.stdscr, h - 1, x_offset, "─" * w, curses.color_pair(C_TITLE) | curses.A_DIM)

