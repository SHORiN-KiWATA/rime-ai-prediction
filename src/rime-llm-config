def parse_models(data):
    if isinstance(data, dict):
        if "data" in data and isinstance(data["data"], list):
            return[(m.get("id") or m.get("name") or "") for m in data["data"] if isinstance(m, dict)]
        if "models" in data and isinstance(data["models"], list):
            return[(m.get("name", "").replace("models/", "") or m.get("id", "")) for m in data["models"] if isinstance(m, dict)]
    if isinstance(data, list):
        return[(m.get("id") or m.get("name") or str(m)) if isinstance(m, dict) else str(m) for m in data]
    return[]

def normalize_api_url(url):
    """
    智能格式化 API URL：将用户模糊输入的 Base URL 或错误的 Endpoint 统一转为标准对话接口。
    """
    url = url.strip().rstrip("/")
    if not url: return url

    url_lower = url.lower()

    if "anthropic" in url_lower or "claude" in url_lower:
        if url_lower.endswith("/models"):
            url = url[:-7] 
        if not url_lower.endswith("/messages"):
            if url_lower.endswith("/v1"): return url + "/messages"
            return url + "/v1/messages"
        return url

    if "11434" in url_lower:
        if url_lower.endswith("/api/tags"): url = url[:-9]
        elif url_lower.endswith("/v1/models"): url = url[:-10]
        elif url_lower.endswith("/models"): url = url[:-7]
        
        if not url_lower.endswith("/chat/completions"):
            if url_lower.endswith("/v1"): return url + "/chat/completions"
            elif url_lower.endswith("/api"): return url + "/chat"
            else: return url + "/v1/chat/completions"
        return url

    if "generativelanguage" in url_lower:
        return url

    if not url_lower.endswith("/chat/completions"):
        if url_lower.endswith("/models"):
            url = url[:-7]
        if url_lower.endswith("/v1"):
            return url + "/chat/completions"
        else:
            return url + "/v1/chat/completions"

    return url

def fetch_models(api_url, api_key):
    url = api_url
    is_anthropic = "anthropic" in url or "/messages" in url

    if "11434" in url:
        url = url.split("/v1/")[0].split("/api/")[0] + "/api/tags"
    elif "generativelanguage.googleapis.com" in url:
        url = "https://generativelanguage.googleapis.com/v1beta/models"
        if api_key: url += f"?key={api_key}"
    elif is_anthropic:
        url = url.replace("/messages", "/models")
    else:
        url = url.replace("/openai/chat/completions", "/models").replace("/chat/completions", "/models").replace("/text/chatcompletion_v2", "/models")
        if not url.endswith("/models") and not url.endswith("/tags"): url = url.rstrip("/") + "/models"

    headers = {"User-Agent": "rime-llm", "Accept": "application/json"}
    
    if api_key and "generativelanguage" not in url:
        if is_anthropic:
            headers["x-api-key"] = api_key
            headers["anthropic-version"] = "2023-06-01"
        else:
            headers["Authorization"] = f"Bearer {api_key}"
            headers["x-api-key"] = api_key

    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=5) as resp:
            return[m for m in parse_models(json.loads(resp.read().decode("utf-8"))) if m], None
    except Exception as e: return[], str(e)

