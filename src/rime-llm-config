# 🚀 主运行程序
# ==========================================

def run_app(stdscr):
    init_colors()
    curses.curs_set(0)
    state = load_state()
    
    while True:
        act_name = state["profiles"].get(state.get("active_profile", ""), {}).get("name", "None")
        main_opts =[
            (t('tui_opt_switch', act_name), "switch"),
            (t('tui_opt_edit'), "edit_profiles"),
            (t('tui_opt_settings'), "edit_settings"),
            (t('tui_opt_vocab'), "edit_vocab"),
            (t('tui_opt_export'), "export")
        ]
        
        choice = menu_dialog(stdscr, t('tui_main_title'), main_opts)
        if choice in (None, "QUIT", "exit"): break
        
        if choice == "switch":
            valid_opts =[]
            for k, v in state["profiles"].items():
                if v.get('api_url') and v.get('api_key') and v.get('model'):
                    valid_opts.append((f"{v.get('name', k)} [{v.get('model')}]", k))
            if not valid_opts:
                msgbox(stdscr, t('msg_info'), t('tui_sw_err'))
                continue
            
            res = menu_dialog(stdscr, t('tui_sw_title'), valid_opts, allow_search=True)
            if res and res != 'QUIT': state["active_profile"] = res; save_state(state)
                
        elif choice == "edit_profiles":
            ProviderEditorTUI(stdscr, state).run()

        elif choice == "edit_settings":
            s = state["settings"]
            
            # 智能检测当前配置是否支持“思考模式”
            active_prof_id = state.get("active_profile", "")
            active_prof = state["profiles"].get(active_prof_id, {})
            url_lower = active_prof.get("api_url", "").lower()
            model_lower = active_prof.get("model", "").lower()

            # 对于 OpenRouter，由于其内部有严格的模型ID隔离机制（如 deepseek-chat 和 deepseek-r1 分别是不同模型），
            # 强行通过参数注入可能会导致 400 错误，因此对包含 openrouter 的配置予以忽略。
            is_openrouter = "openrouter" in url_lower
            
            is_deepseek = "deepseek" in url_lower or "deepseek" in model_lower
            is_gemini = "generativelanguage" in url_lower or "gemini" in model_lower
            is_anthropic = "anthropic" in url_lower or "claude" in model_lower
            supports_thinking = (is_deepseek or is_gemini or is_anthropic) and not is_openrouter
            
            fields_config = [
                {"label": t('tui_st_prompt'), "value": s.get("prompt", ""), "type": "textarea"},
                {"label": t('tui_st_trigger'), "value": s.get("ai_trigger", "v")},
                {"label": t('tui_st_tokens'), "value": str(s.get("max_tokens", 4000))},
                {"label": t('tui_st_temp'), "value": str(s.get("temperature", 0.1))},
                {"label": t('tui_st_time'), "value": str(s.get("max_time", 30.0))}
            ]
            
            if supports_thinking:
                think_opts = ["Disabled", "Enabled (Low)", "Enabled (Medium)", "Enabled (High)"]
                if LANG == "zh":
                    think_opts = ["关闭 (Disabled)", "开启 - 低强度 (Low)", "开启 - 中强度 (Medium)", "开启 - 高强度 (High)"]
                
                fields_config.append({
                    "label": t('tui_st_thinking'),
                    "value": s.get("thinking_mode", think_opts[0]),
                    "type": "select",
                    "options": think_opts
                })

            res = form_dialog(stdscr, t('tui_st_title'), fields_config)
            if res:
                s["prompt"], s["ai_trigger"] = res[0], res[1]
                s["max_tokens"] = int(res[2]) if res[2].isdigit() else 4000
                s["temperature"] = float(res[3]) if res[3].replace('.','',1).isdigit() else 0.1
                s["max_time"] = float(res[4]) if res[4].replace('.','',1).isdigit() else 30.0
                
                if supports_thinking and len(res) > 5:
                    s["thinking_mode"] = res[5]
                
                save_state(state)

        elif choice == "edit_vocab":
            last_deleted_term, last_deleted_map = None, None
            while True:
                v_choice = menu_dialog(stdscr, t('tui_vc_title'),[(t('tui_vc_opt_term'), "terms"), (t('tui_vc_opt_map'), "mapping")])
                if v_choice in (None, 'QUIT'): break
                if v_choice == "terms":
                    while True:
                        terms = state["vocab"].get("terms",[])
                        sel_action, sel_val = menu_dialog(stdscr, t('tui_vc_term_title'), [(t, t) for t in terms] +[(t('tui_vc_add_term'), "NEW")], hint=t('tui_hint_menu_del'), allow_delete=True, allow_undo=True, allow_search=True) or (None, None)
                        if sel_action in (None, 'QUIT'): break
                        if sel_action == 'DELETE':
                            last_deleted_term = sel_val; terms.remove(sel_val); save_state(state)
                        elif sel_action == 'UNDO' and last_deleted_term:
                            terms.append(last_deleted_term); save_state(state); last_deleted_term = None
                        elif sel_action == 'SELECT':
                            if sel_val == "NEW":
                                res = form_dialog(stdscr, t('tui_vc_fm_add_term'), [{"label": t('tui_lbl_term'), "value": ""}])
                                if res and res[0]: terms.append(res[0]); save_state(state)
                            else:
                                res = form_dialog(stdscr, t('tui_vc_fm_edit_term'),[{"label": t('tui_lbl_term'), "value": sel_val}], show_delete=True)
                                if res == "DELETE":
                                    terms.remove(sel_val); save_state(state)
                                elif isinstance(res, list) and res[0].strip():
                                    terms.remove(sel_val); terms.append(res[0].strip()); save_state(state)
                elif v_choice == "mapping":
                    while True:
                        maps = state["vocab"].get("mappings", {})
                        sel_action, sel_val = menu_dialog(stdscr, t('tui_vc_map_title'),[(f"{k} = {v}", k) for k, v in maps.items()] +[(t('tui_vc_add_map'), "NEW")], hint=t('tui_hint_menu_del'), allow_delete=True, allow_undo=True, allow_search=True) or (None, None)
                        if sel_action in (None, 'QUIT'): break
                        if sel_action == 'DELETE':
                            last_deleted_map = (sel_val, maps[sel_val]); del maps[sel_val]; save_state(state)
                        elif sel_action == 'UNDO' and last_deleted_map:
                            maps[last_deleted_map[0]] = last_deleted_map[1]; save_state(state); last_deleted_map = None
                        elif sel_action == 'SELECT':
                            if sel_val == "NEW":
                                res = form_dialog(stdscr, t('tui_vc_fm_add_map'),[{"label": t('tui_lbl_pinyin'), "value": ""}, {"label": t('tui_lbl_result'), "value": ""}])
                                if res and res[0] and res[1]: maps[res[0]] = res[1]; save_state(state)
                            else:
                                res = form_dialog(stdscr, t('tui_vc_fm_edit_map'),[{"label": t('tui_lbl_pinyin'), "value": sel_val}, {"label": t('tui_lbl_result'), "value": maps[sel_val]}], show_delete=True)
                                if res == "DELETE":
                                    del maps[sel_val]; save_state(state)
                                elif isinstance(res, list) and res[0].strip():
                                    del maps[sel_val]; maps[res[0].strip()] = res[1]; save_state(state)

        elif choice == "export":
            try:
                out = export_to_lua(state)
                msgbox(stdscr, t('tui_exp_succ'), t('tui_exp_msg', out))
                break
            except Exception as e:
                msgbox(stdscr, t('tui_exp_err'), str(e))

if __name__ == "__main__": 
    if cli_handler(): sys.exit(0)
    try: curses.wrapper(run_app)
    except KeyboardInterrupt: pass
    except Exception as e: print(f"Fatal error: {e}")
