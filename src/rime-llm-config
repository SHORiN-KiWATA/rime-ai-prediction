C_BLU = '\033[94m'; C_GRN = '\033[92m'; C_YLW = '\033[93m'; C_RED = '\033[91m'
C_CYN = '\033[96m'; C_GRY = '\033[90m'; C_RES = '\033[0m'; C_BLD = '\033[1m'

L_INFO = f"{C_BLU}[INFO]{C_RES}   "
L_OK   = f"{C_GRN}[OK]{C_RES}     "
L_WARN = f"{C_YLW}[WARN]{C_RES}   "
L_ERR  = f"{C_RED}[ERROR]{C_RES}  "
L_SKIP = f"{C_GRY}[SKIP]{C_RES}   "

def backup_file(filepath):
    if not os.path.exists(filepath): return
    backup_dir = os.path.expanduser("~/.cache/rime-llm-config/backup/")
    os.makedirs(backup_dir, exist_ok=True)
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    basename = os.path.basename(filepath)
    backup_path = os.path.join(backup_dir, f"{basename}.{timestamp}.bak")
    shutil.copy2(filepath, backup_path)
    print(f"{L_INFO} " + t("cli_bk_create", backup_path))

def restart_fcitx5():
    try:
        if subprocess.run(["pgrep", "-x", "fcitx5"], capture_output=True).returncode != 0:
            print(f"{L_INFO} " + t("cli_fcitx_not_run"))
            return
        print(f"{L_INFO} " + t("cli_fcitx_restarting"))
        if shutil.which("systemctl"):
            res = subprocess.run(["systemctl", "--user", "is-active", "fcitx5"], capture_output=True, text=True)
            if res.stdout.strip() == "active":
                subprocess.run(["systemctl", "--user", "restart", "fcitx5"])
                print(f"{L_OK} " + t("cli_fcitx_ok_sysd"))
                return
        subprocess.Popen(["fcitx5", "-r", "-d"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print(f"{L_OK} " + t("cli_fcitx_ok_cli"))
    except Exception as e:
        print(f"{L_WARN} " + t("cli_fcitx_fail", str(e)))

